# 腾讯云 API 密钥
# 在 https://console.cloud.tencent.com/cam/capi 获取
TENCENT_SECRET_ID=你的腾讯云SecretID
TENCENT_SECRET_KEY=你的腾讯云SecretKey

# 腾讯云地域（语音服务一般用 ap-guangzhou）
TENCENT_REGION=ap-guangzhou

# 腾讯云 CloudBase 环境 ID
TCB_ENV_ID=你的CloudBase环境ID

# 混元大模型（可选，默认 hunyuan-turbos-latest）
HUNYUAN_MODEL=hunyuan-turbos-latest

# AI/语音供应商切换
# 默认保持现有能力：混元主对话 + 腾讯 ASR/TTS
LLM_PROVIDER=hunyuan
VOICE_PROVIDER=tencent

# 火山方舟主对话（当 LLM_PROVIDER=doubao 时使用）
ARK_API_KEY=你的火山方舟ARK_API_KEY
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_CHAT_MODEL=你的火山方舟ep接入点

# 豆包语音（当 VOICE_PROVIDER=doubao 时使用）
# 新版控制台通常使用 DOUBAO_SPEECH_API_KEY；如你的账号拿到的是 App Key / Access Key，也预留了兼容位置。
DOUBAO_SPEECH_API_KEY=你的豆包语音API_Key
DOUBAO_SPEECH_APP_KEY=你的豆包语音App_Key
DOUBAO_SPEECH_APP_ID=你的豆包语音App_ID
DOUBAO_SPEECH_ACCESS_KEY=你的豆包语音Access_Key
DOUBAO_ASR_RESOURCE_ID=volc.bigasr.auc_turbo
DOUBAO_ASR_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
DOUBAO_TTS_RESOURCE_ID=你的豆包语音合成资源ID
DOUBAO_TTS_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
DOUBAO_TTS_VOICE=你的默认TTS音色ID
DOUBAO_TTS_FORMAT=mp3
DOUBAO_TTS_SAMPLE_RATE=16000

# AI 角色设定
AI_SYSTEM_PROMPT=你是故事坊的AI助手，专门帮助老年人记录家庭故事和记忆。请用温暖、耐心、简洁的语气回复，每次回复不超过100字。鼓励老人继续讲述，适当提问引导。

# 管理员账号
ADMIN_PHONE=你的管理员手机号
ADMIN_PASSWORD=你的管理员密码

# DeepSeek API（用于叙事摘要提取和自传撰写）
DEEPSEEK_API_KEY=你的DeepSeek_API_Key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BIOGRAPHY_MODEL=deepseek-v4-pro
